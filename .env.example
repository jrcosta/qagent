# LLM provider used by QAgent.
# Current default implementation expects an OpenAI-compatible Groq endpoint.
LLM_PROVIDER=groq

# Model used by the agents.
# Recommended Groq example:
LLM_MODEL=groq/llama-3.3-70b-versatile

# API key used by the configured LLM provider.
# Never commit a real key here.
LLM_API_KEY=

# Optional OpenAI-compatible base URL.
# Keep this value for Groq.
LLM_BASE_URL=https://api.groq.com/openai/v1

# Agent temperature.
# Use 0 for deterministic CI/review flows, 0.2 for local experimentation.
LLM_TEMPERATURE=0.2

# Optional GitHub token/PAT used by flows that create branches, PRs or statuses.
# Prefer repository secrets in GitHub Actions.
GITHUB_TOKEN=
